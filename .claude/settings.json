{
  "permissions": {
    "deny": [
      "Bash(git stash*)"
    ],
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(bun run *)",
      "Bash(git log *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(echo *)",
      "Edit(./*)",
      "Write(./*)",
      "MultiEdit(./*)"
    ],
    "additionalDirectories": [
      "../photosphere.wiki"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if git status --porcelain | grep -qE '\\.tsx?$'; then bun run compile; fi",
            "timeout": 120,
            "statusMessage": "Compiling..."
          },
          {
            "type": "command",
            "command": "if git status --porcelain | grep -qE '\\.tsx?$'; then bun run test:cli; fi",
            "timeout": 120,
            "statusMessage": "Testing..."
          }
        ]
      }
    ]
  }
}
