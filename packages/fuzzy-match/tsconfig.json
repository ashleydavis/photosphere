{
    "include": [
        "src/**/*"
    ],
    "compilerOptions": {
        "composite": true,
        "target": "ES2020",
        "module": "ESNext",
        "rootDir": "./src",
        "moduleResolution": "bundler",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "./build",
        "noEmit": true,
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    }
}
