{
  "name": "photosphere",
  "version": "0.0.1",
  "description": "Photosphere: Photo and video management",
  "author": {
    "name": "Ashley Davis",
    "email": "ashley@codecapers.com.au"
  },
  "homepage": "https://github.com/ashleydavis/photosphere",
  "license": "MIT",
  "private": true,
  "main": "bundle/main.js",
  "scripts": {
    "dev": "bun run bundle && electron . --no-sandbox",
    "dev:fps": "bun run bundle && FPS_LOGGING=1 electron . --no-sandbox",
    "compile": "tsc --noEmit",
    "c": "bun run compile",
    "bundle:main": "bun build ./src/main.ts --outdir ./bundle --target node --format cjs --external electron",
    "bundle:preload": "bun build ./src/preload.ts --outdir ./bundle --target node --format cjs --external electron",
    "bundle:worker": "bun build ./src/worker.ts --outdir ./bundle --target node --format cjs",
    "bundle:rest-api-worker": "bun build ./src/rest-api-worker.ts --outdir ./bundle --target node --format cjs",
    "bundle": "bun bundle:main && bun bundle:preload && bun bundle:worker && bun bundle:rest-api-worker",
    "build": "bun run bundle && electron-builder",
    "setup-electron-builder": "powershell -ExecutionPolicy Bypass -File scripts/setup-electron-builder.ps1",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:smoke:gui": "cross-env SHOW_GUI=1 playwright test tests/smoke.spec.ts",
    "test:post-install": "bash scripts/test-post-install.sh"
  },
  "dependencies": {
    "task-queue": "workspace:*",
    "api": "workspace:*",
    "utils": "workspace:*",
    "config": "workspace:*",
    "node-utils": "workspace:*",
    "electron-defs": "workspace:*",
    "serialize-error": "^11.0.0",
    "rest-api": "workspace:*",
    "tools": "workspace:*",
    "vault": "workspace:*",
    "storage": "workspace:*",
    "lan-share": "workspace:*"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^40.0.0",
    "@types/node": "^20.10.0",
    "electron-builder": "^26.4.0",
    "typescript": "^5.3.3",
    "@playwright/test": "^1.57.0"
  },
  "build": {
    "appId": "com.codecapers.photosphere",
    "productName": "Photosphere",
    "electronVersion": "40.0.0",
    "directories": {
      "output": "release"
    },
    "files": [
      "bundle/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": ["dmg", "zip"],
      "artifactName": "photosphere-desktop-${version}-mac-${arch}.${ext}",
      "executableName": "photosphere"
    },
    "win": {
      "target": ["nsis", "zip"],
      "artifactName": "photosphere-desktop-${version}-win-${arch}.${ext}",
      "executableName": "photosphere"
    },
    "linux": {
      "target": ["deb", "zip"],
      "maintainer": "ashley@codecapers.com.au",
      "artifactName": "photosphere-desktop-${version}-linux-${arch}.${ext}",
      "executableName": "photosphere",
      "extraFiles": [
        {
          "from": "scripts/fix-sandbox.sh",
          "to": "scripts/fix-sandbox.sh"
        },
        {
          "from": "scripts/README.md",
          "to": "README.md"
        }
      ]
    },
    "deb": {
      "afterInstall": "./scripts/deb-post-install.sh"
    }
  }
}

