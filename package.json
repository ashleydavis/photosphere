{
  "name": "photosphere-monorepo",
  "version": "1.0.0",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashleydavis/photosphere.git"
  },
  "bugs": {
    "url": "https://github.com/ashleydavis/photosphere/issues"
  },
  "description": "This monorepo contains the backend and frontend for [the Photosphere application](https://rapidfullstackdevelopment.com/example-application).",
  "homepage": "https://github.com/ashleydavis/photosphere#readme",
  "keywords": [],
  "license": "MIT",
  "scripts": {
    "c": "bun run compile",
    "compile": "bun --filter '*' compile",
    "clean": "bun --filter '*' clean",
    "test": "bun --filter '*' test",
    "test:watch": "bun --filter '*' test:watch",
    "test:all": "bun run test && bun run test:cli && bun run test:cli:encrypted && bun run test:cli:lan-share && bun run test:electron",
    "t": "bun run test",
    "tw": "bun run test:watch",
    "ta": "bun run test:all",
    "dev": "bun run bundle:renderer && bun run --filter=photosphere dev",
    "dev:fps": "bun run bundle:renderer && bun run --filter=photosphere dev:fps",
    "dev:web": "concurrently --kill-others --names \"server,frontend\" \"bun run --filter=dev-server dev\" \"bun run --filter=photosphere-frontend dev\"",
    "d": "bun run dev",
    "build": "bun run bundle:renderer && bun run --filter=photosphere build",
    "bundle:main": "bun run --filter=photosphere bundle",
    "bundle:renderer": "bun run --filter=desktop-frontend bundle",
    "bundle": "bun run bundle:main && bun run bundle:renderer",
    "smoke": "bun run test:cli && bun run test:electron",
    "test:electron": "cd ./apps/desktop/ && ./smoke-tests.sh",
    "test:electron:seq": "cd ./apps/desktop/ && ./smoke-tests.sh --sequential",
    "te": "bun run test:electron",
    "test:cli": "cd ./apps/cli && ./smoke-tests.sh",
    "tc": "cd ./apps/cli && ./smoke-tests.sh",
    "test:cli:encrypted": "cd ./apps/cli/ && ./smoke-tests-encrypted.sh",
    "tce": "bun run test:cli:encrypted",
    "test:cli:lan-share": "cd ./apps/cli/ && ./smoke-tests-lan-share.sh",
    "tcl": "bun run test:cli:lan-share",
    "test:lan-share:cli-desktop": "./cli-desktop-lan-share-smoke-tests.sh",
    "tlcd": "bun run test:lan-share:cli-desktop",
    "perf": "bun --filter '*' perf"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "aux/*"
  ]
}
